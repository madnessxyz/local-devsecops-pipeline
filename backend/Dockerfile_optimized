# Stage 1: Build & Dependencies
FROM node:21-alpine AS builder
WORKDIR /app
COPY package*.json ./
# Install ALL dependencies to ensure smooth utility script compilation
RUN npm ci

COPY . .

# Stage 2: Clean Production Runtime
FROM node:21-alpine
WORKDIR /app

# Explicitly create our non-root security user application account
RUN addgroup -S appgroup && adduser -S appuser -G appgroup

# Copy everything including the compiled node_modules straight from the builder stage
COPY --from=builder --chown=appuser:appgroup /app /app

USER appuser
EXPOSE 5000

CMD ["node", "server.js"]
